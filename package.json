    "build:frontend": "cd frontend && npm run build",
    "start:all:win": "powershell -ExecutionPolicy Bypass -File ./start-all.ps1",
    "run:backend:ps1": "powershell -ExecutionPolicy Bypass -File ./run-backend.ps1"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
